# Copy to .env and fill in. .env is gitignored.

# Cloudflare tunnel token (from: the 'laurendavisphoto' named tunnel).
CF_TUNNEL_TOKEN=

# Who may use /admin. Cloudflare Access is the real gate at the edge; this is a
# defense-in-depth allow-list the app also checks (comma-separated emails).
ADMIN_EMAILS=lauren.davis@dw-r.com,jd@peace22.com

# AI feature-coder backend(s). First is the default shown in the UI.
FEATURE_CODERS=qwen
FEATURE_CODER_URL=http://10.100.0.13:8080/v1/chat/completions
FEATURE_CODER_MODEL=qwen3.6-35b
